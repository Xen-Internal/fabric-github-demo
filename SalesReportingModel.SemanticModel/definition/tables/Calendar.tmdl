		lineageTag: e66f1fc0-5adf-4918-a8c7-1a06fd6cf532
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column QuarterName = SWITCH('Calendar'[Fiscal Quarter],1,"AMJ",2,"JAS",3,"OND","JFM")
		lineageTag: a47668be-3007-4090-be16-778493b4b0c8
		summarizeBy: none

