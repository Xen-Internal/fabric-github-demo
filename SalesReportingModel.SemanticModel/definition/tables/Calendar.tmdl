		sortByColumn: 'Fiscal Month'

		annotation SummarizationSetBy = Automatic

	column 'Fiscal Year' = IF([Month]<=3,"FY "&RIGHT(YEAR([Date])-1,2)&"-"&RIGHT(YEAR([Date]),2),"FY "&RIGHT(YEAR([Date]),2)&"-"&RIGHT(YEAR([Date])+1,2))
		lineageTag: e07a9a68-2a18-45ba-9239-de5047a4d795
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Fiscal Month' = Month(EDATE([Date],-3))
		formatString: 0
		lineageTag: 6d058f17-ae79-4f6f-91e5-9d2e388d3590
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Fiscal Quarter' = QUARTER(EDATE([Date],-3))
