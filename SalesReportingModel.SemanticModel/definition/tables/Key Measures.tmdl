			                & ( MID ( MAX ( 'Calendar'[Fiscal Year] ), 3, 3 ) - 1 )
			                & "-"
			                & ( RIGHT ( MAX ( 'Calendar'[Fiscal Year] ), 2 ) - 1 ),
			        'Calendar'[Month] = MONTH ( TODAY() ) - 1
			    ),
			    IF (
			        MONTH ( TODAY() ) = 1,
			        CALCULATE ([Annual License Revenue],
			            
			            'Calendar'[Month] = 12
			        ),
			        CALCULATE (
			            [Annual License Revenue],
			            
			            'Calendar'[Month] = MONTH ( TODAY() ) - 1
			        )
			    )
			)
			RETURN
			IF(last=BLANK(),0,last)
			
			```
