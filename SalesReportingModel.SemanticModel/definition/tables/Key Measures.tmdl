	measure 'Last Month - Total Projects' = ```
			
			var CurrMoth=month(TODAY())
			var CurrYear=Year(TODAY())
			var prevMonth=IF(CurrMoth=1,12,CurrMoth-1)
			var prevYear=if(prevMonth=12,max('Calendar'[Year])-1,max('Calendar'[Year]))
			return
			CALCULATE([Total Projects],'Calendar'[Month]=prevMonth,'Calendar'[Year]=prevYear)
			
			
			```
		formatString: 0
		lineageTag: 5d84ab70-7bfb-49be-b7bd-22e07af483fe

	measure text_PM = "LM : "
		lineageTag: d785cd01-4398-48c5-92c7-7f30f19fa307

	measure 'MoM Growth - Total Projects' =
			
			var No_projects=[Total Projects]
			var current_month=CALCULATE([Total Projects],'Calendar'[Month]=MONTH(TODAY()))
			var previous_month=SWITCH(month(TODAY()),4,4,5,4,6,5,7,6,8,7,9,8,10,9,11,10,12,11,1,12,2,1,3,2)
			var previous_month_projects=CALCULATE([Total Projects],'Calendar'[Month]=previous_month)
			var no_month=SWITCH(month(TODAY()),4,1,5,1,6,2,7,3,8,4,9,5,10,6,11,7,12,8,1,9,2,10,3,11)
			var Month_projects=No_projects-current_month
			var Average_projects=Month_projects/no_month
			return
			DIVIDE((previous_month_projects-Average_projects),(Average_projects))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: eccd5001-83d5-495a-8f60-f5407a41e009

