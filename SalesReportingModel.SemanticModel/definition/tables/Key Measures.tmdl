	measure 'Total Projects' =
			
			var projects=DISTINCTCOUNT('PreSales Tracker'[Project Name])
			var new=CALCULATE(projects,USERELATIONSHIP('Calendar'[Date],'PreSales Tracker'[Created]))
			RETURN
			if(new=BLANK(),0,new)
		formatString: 0
		lineageTag: 77ceec88-0b63-4eaa-8430-a2f3df920f39

