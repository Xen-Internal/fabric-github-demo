	measure change_Style2 =
			
			"<div style='font-family:calibri; font-size:18px; line-height:1.7em; text-align:center;'>" &
			"<h1 style='margin-bottom:10px; font-size:20px; font-family:calibri; font-weight:bold;'>
			Here's a summary of the key insights from Pre-Sales dashboard for
			<span style='color:#FFFFFF; font-weight:bold;'>" & [currentFY] & "</span></h1>" &
			
			"<ul style='list-style-position:inside; text-align:center; padding:0; margin:15px 0; display:inline-block;'>" &
			"<li style='font-size:20px; text-align:left;'>Total No of Projects : <span style='color:#FFFFFF; font-weight:bold; font-size:16px;'>" & [Total Projects] & "</span></li>" &
			"<li style='font-size:20px; text-align:left;'> Total ACR : <span style='color:#FFFFFF; font-weight:bold; font-size:16px;'>" & [Total ACR (USD)] & "</span></li>" &
			"<li style='font-size:20px; text-align:left;'> Total MRR : <span style='color:#FFFFFF; font-weight:bold; font-size:16px;'>" & [Total MRR] & "</span></li>" &
			"</ul>" &
			
			"</div>"
		lineageTag: e73dc111-2db3-461f-b8c5-08c62b057b49

	measure currentFY =
			
			VAR TodayDate = TODAY()
			VAR CurrentYear = YEAR(TodayDate)
			VAR CurrentMonth = MONTH(TodayDate)
			-- If fiscal year starts in April (i.e., Month 4)
			VAR FYStartMonth = 5
			VAR FYStartYear =
			    IF(CurrentMonth >= FYStartMonth, CurrentYear, CurrentYear - 1)
			VAR FYEndYear = FYStartYear + 1
			RETURN
			    "FY " &
			    RIGHT(FYStartYear, 2) & "-" &
			    RIGHT(FYEndYear, 2)
		lineageTag: 4fe5eb70-e20b-438a-9a92-40b51af4b36a

	measure change_Style3 =
			
			"<div style='font-family:calibri; font-size:18px; line-height:1.7em; text-align:center; color:#FFFFFF;'>" &
			"<h1 style='margin-bottom:10px; font-size:20px; font-family:calibri; font-weight:bold; color:#FFFFFF;'>
			Here's a summary of the key insights from Pre-sales dashboard for
			<span style='color:#FFFFFF; font-weight:bold;'>" & [currentFY] & "</span></h1>" &
			
			"<ul style='list-style-position:inside; text-align:center; padding:0; margin:15px 0; display:inline-block; color:#FFFFFF;'>" &
			"<li style='font-size:20px; text-align:left; color:#FFFFFF;'>Total No of Opportunities : <span style='color:#FFFFFF; font-weight:bold; font-size:20px;'>" & [Total Projects] & "</span></li>" &
			"<li style='font-size:20px; text-align:left; color:#FFFFFF;'> Active Opportunities : <span style='color:#FFFFFF; font-weight:bold; font-size:20px;'>"  &[Active Opportunities]  &  "</span></li>" &
