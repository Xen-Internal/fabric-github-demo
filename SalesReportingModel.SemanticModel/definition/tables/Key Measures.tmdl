	measure 'Last Month - MRR ($)' = ```
			
			IF (
			    MONTH ( TODAY() ) = 4,
			    CALCULATE (
			        [Total MRR],
			        
			        'Calendar'[Fiscal Year]
			            = "FY "
			                & ( MID ( MAX ( 'Calendar'[Fiscal Year] ), 3, 3 ) - 1 )
			                & "-"
			                & ( RIGHT ( MAX ( 'Calendar'[Fiscal Year] ), 2 ) - 1 ),
			        'Calendar'[Month] = MONTH ( TODAY() ) - 1
			    ),
			    IF (
			        MONTH ( TODAY() ) = 1,
			        CALCULATE (
			            [Total MRR],
			            
			            'Calendar'[Month] = 12
			        ),
			        CALCULATE (
			            [Total MRR],
			            
			            'Calendar'[Month] = MONTH ( TODAY() ) - 1
			        )
			    )
			)
			
