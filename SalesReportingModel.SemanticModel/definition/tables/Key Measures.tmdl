	measure Greeting = ```
			
			VAR CurrentDateTime = NOW()+TIME(5,30,0)  -- Adjusting for timezone (5.5 hours ahead)
			VAR Hour_ = HOUR(CurrentDateTime)
			VAR Minute_ = MINUTE(CurrentDateTime)
			VAR TimeInMinutes = Hour_ * 60 + Minute_
			
			-- Greeting based on more accurate time:
			VAR greet = 
			    SWITCH(
			        TRUE(),
			        TimeInMinutes < 720, "😊 Good morning, ",                   -- Before 12:00 PM
			        TimeInMinutes >= 720 && TimeInMinutes < 1020, "😊 Good afternoon, ",  -- 12:00 PM to 5:00 PM
			        "😊 Good evening, "                                         -- After 5:00 PM
			    )
			
			-- Extract user's first and last name from email:
			VAR UseName = LEFT(USERPRINCIPALNAME(), FIND("@", USERPRINCIPALNAME()) - 1)
			VAR FirstName = 
			    UPPER(LEFT(UseName, 1)) & 
			    MID(UseName, 2, FIND(".", UseName) - 2)
			VAR LastName = 
			    UPPER(LEFT(MID(UseName, FIND(".", UseName) + 1, LEN(UseName)), 1)) & 
			    MID(UseName, FIND(".", UseName) + 2, LEN(UseName)) 
			
			VAR new = FirstName & " " & LastName
			
			RETURN
			greet & new
			```
		lineageTag: 14c9e339-6186-4ef5-9456-9a061dc9b699

