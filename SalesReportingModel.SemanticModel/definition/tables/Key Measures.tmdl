	measure 'Average win%' =
			
			var Deal_won=CALCULATE(count('PreSales Tracker'[Win]),'PreSales Tracker'[Deal Status]="Deal Won")
			var Deal_Lost_Won=CALCULATE(count('PreSales Tracker'[Win]),'PreSales Tracker'[Deal Status] in {"Deal Won","Lost","Dropped"})
			var new=Deal_won/Deal_Lost_Won
			RETURN
			if(new=BLANK(),0,new)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3dc4e674-68a6-4c69-9708-fac7cc5273e6

