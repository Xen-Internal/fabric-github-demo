	measure 'Second Last Month - ACR' = ```
			
			VAR CurrMonth = MONTH ( TODAY() )
			VAR CurrYear  = YEAR ( TODAY() )
			
			VAR TwoMonthsBackMonth =
			    SWITCH (
			        CurrMonth,
