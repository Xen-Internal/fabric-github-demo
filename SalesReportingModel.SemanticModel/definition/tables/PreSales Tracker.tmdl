	column 'Deal Status Group' = ```
			
			SWITCH (
			    TRUE(),
			    'PreSales Tracker'[Deal Status] IN { "Hot Lead" }, "Hot",
			    'PreSales Tracker'[Deal Status] IN { "Warm Lead" }, "Warm",
			    'PreSales Tracker'[Deal Status] IN { "Cold Lead" }, "Cold",
			    'PreSales Tracker'[Deal Status] IN { "Deal Won", "Won" }, "Deal Won",
			    'PreSales Tracker'[Deal Status] IN { "Lost", "Dropped" }, "Lost",
			    'PreSales Tracker'[Deal Status] IN { "On Hold", "Follow up", "Proposal Submitted" }, "In Progress",
			    "Others"
			)
			
			```
		lineageTag: 64fabcc8-1e7f-40fc-b2e4-29d288732e16
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Stage Rank' = ```
			
			SWITCH(
			    TRUE(),
			    'PreSales Tracker'[Deal Status] = "Cold Lead", 1,
			    'PreSales Tracker'[Deal Status] = "Warm Lead", 2,
			    'PreSales Tracker'[Deal Status] = "Hot Lead", 3,
			
			    'PreSales Tracker'[Deal Status] IN {"Follow up", "Proposal Submitted", "On Hold","Others"}, 4,
			
			    'PreSales Tracker'[Deal Status] IN {"Deal Won", "Won"}, 6,
			    'PreSales Tracker'[Deal Status] IN {"Lost","Dropped"},5,
			    BLANK()
			)
			
			```
		formatString: 0
		lineageTag: 3bc31229-b307-44e8-a2c0-589d3f87fc02
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

