table 'PreSales Tracker'
	lineageTag: 328ef0d0-9c40-4540-bcbc-4aac3019115c

	measure 'Won Deals' = CALCULATE([Total Projects],'PreSales Tracker'[Deal Status]="Deal Won")
		formatString: 0
		lineageTag: 0301ead6-e8aa-4d85-abcb-4c5fbd47e139

	measure 'Lost Deals' = CALCULATE([Total Projects],'PreSales Tracker'[Deal Status] in ({"Lost","Dropped"}))
		formatString: 0
		lineageTag: cf49955f-97f0-4d71-801f-5d20d22230d8

	measure 'In Progress Deals' = CALCULATE([Total Projects],not('PreSales Tracker'[Deal Status] in {"Deal Won","Lost","Dropped"}))
		formatString: 0
		lineageTag: 5f1867cb-2989-4f0e-ac9b-af1f88510b0c

	measure Avg_Days_Taken = ROUNDUP(CALCULATE(AVERAGE('PreSales Tracker'[Avg Days Taken]),'PreSales Tracker'[Deal Status]="Deal Won"),0)
		formatString: 0
		lineageTag: f48e238b-7556-49bc-9568-f000dbf20e87

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Progressive Funnel Projects' = ```
			
			VAR SelectedRank = SELECTEDVALUE('Funnel Stages'[Stage Rank])
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('PreSales Tracker'[Project Name]),
			    FILTER(
			        'PreSales Tracker',
			        'PreSales Tracker'[Stage Rank] >= SelectedRank
			    )
			)
			
			```
		formatString: 0
		lineageTag: bdfac363-83d0-49c1-878a-c58a957a8ff2

	measure 'Future Followups Count' = ```
			
			COUNTROWS(
			    FILTER(
			        'PreSales Tracker',
			        'PreSales Tracker'[Next Follow up]> TODAY()
			    )
			)
			
			```
		formatString: 0
		lineageTag: fc9cf709-fa2f-4069-9d48-57031c0a4ebd

	measure status_wondeal =
			
			var wondeals=CALCULATE([Total Projects],'PreSales Tracker'[Deal Status]="Deal Won")
			var lostdeals=CALCULATE([Total Projects],'PreSales Tracker'[Deal Status]="Lost")
			RETURN
			IF(wondeals=BLANK(),"No Data To Display",IF(lostdeals=BLANK(),"No Data To Display",""))
		lineageTag: 4ad85f97-b745-4304-9445-9dc2a6ef913f

	measure status_lostdeal =
			
			var wondeals=CALCULATE([Total Projects],'PreSales Tracker'[Deal Status]="Lost")
			RETURN
			IF(wondeals=BLANK(),"No Data To Display","")
		lineageTag: 61bc3fb2-97ad-4ee2-af30-71ffdd8b52eb

	measure 'Projects Closing This Month' =
			
			CALCULATE(
			    [Total Projects],
			    FILTER(
			        ALL('PreSales Tracker'),
			        MONTH('PreSales Tracker'[Closure Date]) = MONTH(TODAY()) &&
			        YEAR('PreSales Tracker'[Closure Date]) = YEAR(TODAY())
			    )
			)
		formatString: 0
		lineageTag: 462d0cf8-15c6-463c-9cad-e76ec0b4b1da

